generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Video {
  id          String   @id @default(cuid())
  title       String
  url         String
  provider    String
  videoId     String
  aspectRatio String   @default("16:9")
  tag         String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model SiteContent {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())
}

model Visit {
  id          String   @id @default(cuid())
  path        String
  fingerprint String
  country     String?
  durationMs  Int?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([fingerprint])
}
